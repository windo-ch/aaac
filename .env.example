# Crossmint
NEXT_PUBLIC_CROSSMINT_CLIENT_ID=your_crossmint_client_id_here

# Optional: Crossmint environment (staging | production)
NEXT_PUBLIC_CROSSMINT_ENV=staging

# Payload CMS
PAYLOAD_SECRET=change-this-to-a-random-secret-string

# Turso (SQLite cloud) — https://turso.tech
DATABASE_URI=libsql://your-db-name.turso.io
DATABASE_AUTH_TOKEN=your_turso_auth_token_here

# Vercel Blob storage — https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token_here
